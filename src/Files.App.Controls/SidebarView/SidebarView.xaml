<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
	xmlns:local="using:Files.App.Controls">

	<Style BasedOn="{StaticResource DefaultSidebarView2Style}" TargetType="local:SidebarView2" />

	<Thickness x:Key="SidebarViewItemsControlMargin">8,8,8,8</Thickness>
	<x:Double x:Key="SidebarViewItemsControlSpacing">4</x:Double>
	<x:Double x:Key="SidebarViewPaneButtonWidth">40</x:Double>
	<x:Double x:Key="SidebarViewPaneButtonHeight">32</x:Double>

	<DataTemplate x:Key="DefaultSidebarViewFlatItemTemplate">
		<local:SidebarViewItem
			Margin="{Binding SectionGapMargin}"
			AutomationProperties.AutomationId="{Binding Item.Text}"
			ContentOpacity="{Binding RowOpacity}"
			Decorator="{Binding Item.ItemDecorator}"
			Depth="{Binding Depth}"
			Icon="{Binding Item.IconElement}"
			IsExpanded="{Binding Item.IsExpanded, Mode=TwoWay}"
			Item="{Binding Item}"
			ItemValue="{Binding Item}"
			Text="{Binding Item.Text}"
			ToolTip="{Binding Item.ToolTip}" />
	</DataTemplate>

	<Style x:Key="DefaultSidebarView2Style" TargetType="local:SidebarView2">
		<Setter Property="Background" Value="{ThemeResource ControlFillColorTransparentBrush}" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="HorizontalContentAlignment" Value="Stretch" />
		<Setter Property="VerticalAlignment" Value="Stretch" />
		<Setter Property="VerticalContentAlignment" Value="Stretch" />
		<Setter Property="PaneBackground" Value="{ThemeResource SidebarViewDefaultPaneBackground}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="local:SidebarView2">
					<Grid TabFocusNavigation="Local">
						<SplitView
							x:Name="PART_RootSplitView"
							CompactPaneLength="{TemplateBinding CompactPaneLength}"
							DisplayMode="Inline"
							IsPaneOpen="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsPaneOpen, Mode=TwoWay}"
							OpenPaneLength="{TemplateBinding OpenPaneLength}"
							PaneBackground="{TemplateBinding PaneBackground}"
							PanePlacement="Left"
							TabFocusNavigation="Local">
							<SplitView.Pane>
								<Grid
									x:Name="PART_PaneColumnGrid"
									HorizontalAlignment="Stretch"
									VerticalAlignment="Stretch"
									Background="Transparent"
									BorderBrush="Transparent"
									BorderThickness="0"
									XYFocusKeyboardNavigation="Enabled">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="*" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<Button
										x:Name="PART_BackButton"
										Grid.Row="0"
										Width="{StaticResource SidebarViewPaneButtonWidth}"
										Height="{StaticResource SidebarViewPaneButtonHeight}"
										Margin="8,8,8,4"
										HorizontalAlignment="Left"
										AutomationProperties.Name="Back"
										IsEnabled="{TemplateBinding IsBackEnabled}"
										ToolTipService.ToolTip="Back"
										Visibility="Collapsed">
										<AnimatedIcon
											Width="16"
											Height="16"
											HorizontalAlignment="Center"
											VerticalAlignment="Center"
											AnimatedIcon.State="Normal"
											AutomationProperties.AccessibilityView="Raw"
											MirroredWhenRightToLeft="True">
											<animatedvisuals:AnimatedBackVisualSource />
											<AnimatedIcon.FallbackIconSource>
												<FontIconSource
													FontSize="16"
													Glyph="&#xE72B;"
													MirroredWhenRightToLeft="True" />
											</AnimatedIcon.FallbackIconSource>
										</AnimatedIcon>
										<Button.Resources>
											<ResourceDictionary>
												<ResourceDictionary.ThemeDictionaries>
													<ResourceDictionary x:Key="Default">
														<StaticResource x:Key="ButtonBackground" ResourceKey="SidebarViewItemBackground" />
														<StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="SidebarViewItemBackgroundPointerOver" />
														<StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="SidebarViewItemBackgroundPressed" />
														<StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="SidebarViewItemBackgroundDisabled" />
														<StaticResource x:Key="ButtonBorderBrush" ResourceKey="SidebarViewItemBorderBrush" />
														<StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="SidebarViewItemBorderBrushPointerOver" />
														<StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="SidebarViewItemBorderBrushPressed" />
														<StaticResource x:Key="ButtonBorderBrushDisabled" ResourceKey="SidebarViewItemBorderBrushDisabled" />
													</ResourceDictionary>
													<ResourceDictionary x:Key="HighContrast">
														<StaticResource x:Key="ButtonBackground" ResourceKey="SidebarViewItemBackground" />
														<StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="SidebarViewItemBackgroundPointerOver" />
														<StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="SidebarViewItemBackgroundPressed" />
														<StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="SidebarViewItemBackgroundDisabled" />
														<StaticResource x:Key="ButtonBorderBrush" ResourceKey="SidebarViewItemBorderBrush" />
														<StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="SidebarViewItemBorderBrushPointerOver" />
														<StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="SidebarViewItemBorderBrushPressed" />
														<StaticResource x:Key="ButtonBorderBrushDisabled" ResourceKey="SidebarViewItemBorderBrushDisabled" />
													</ResourceDictionary>
													<ResourceDictionary x:Key="Light">
														<StaticResource x:Key="ButtonBackground" ResourceKey="SidebarViewItemBackground" />
														<StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="SidebarViewItemBackgroundPointerOver" />
														<StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="SidebarViewItemBackgroundPressed" />
														<StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="SidebarViewItemBackgroundDisabled" />
														<StaticResource x:Key="ButtonBorderBrush" ResourceKey="SidebarViewItemBorderBrush" />
														<StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="SidebarViewItemBorderBrushPointerOver" />
														<StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="SidebarViewItemBorderBrushPressed" />
														<StaticResource x:Key="ButtonBorderBrushDisabled" ResourceKey="SidebarViewItemBorderBrushDisabled" />
													</ResourceDictionary>
												</ResourceDictionary.ThemeDictionaries>
											</ResourceDictionary>
										</Button.Resources>
									</Button>

									<Button
										x:Name="PART_PaneToggleButton"
										Grid.Row="1"
										Width="{StaticResource SidebarViewPaneButtonWidth}"
										Height="{StaticResource SidebarViewPaneButtonHeight}"
										Margin="8,0,8,4"
										HorizontalAlignment="Left"
										AutomationProperties.Name="Open navigation pane"
										ToolTipService.ToolTip="Open navigation pane"
										Visibility="Collapsed">
										<AnimatedIcon
											Width="16"
											Height="16"
											HorizontalAlignment="Center"
											VerticalAlignment="Center"
											AnimatedIcon.State="Normal"
											AutomationProperties.AccessibilityView="Raw">
											<animatedvisuals:AnimatedGlobalNavigationButtonVisualSource />
											<AnimatedIcon.FallbackIconSource>
												<FontIconSource FontSize="16" Glyph="&#xE700;" />
											</AnimatedIcon.FallbackIconSource>
										</AnimatedIcon>
										<Button.Resources>
											<ResourceDictionary>
												<ResourceDictionary.ThemeDictionaries>
													<ResourceDictionary x:Key="Default">
														<StaticResource x:Key="ButtonBackground" ResourceKey="SidebarViewItemBackground" />
														<StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="SidebarViewItemBackgroundPointerOver" />
														<StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="SidebarViewItemBackgroundPressed" />
														<StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="SidebarViewItemBackgroundDisabled" />
														<StaticResource x:Key="ButtonBorderBrush" ResourceKey="SidebarViewItemBorderBrush" />
														<StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="SidebarViewItemBorderBrushPointerOver" />
														<StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="SidebarViewItemBorderBrushPressed" />
														<StaticResource x:Key="ButtonBorderBrushDisabled" ResourceKey="SidebarViewItemBorderBrushDisabled" />
													</ResourceDictionary>
													<ResourceDictionary x:Key="HighContrast">
														<StaticResource x:Key="ButtonBackground" ResourceKey="SidebarViewItemBackground" />
														<StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="SidebarViewItemBackgroundPointerOver" />
														<StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="SidebarViewItemBackgroundPressed" />
														<StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="SidebarViewItemBackgroundDisabled" />
														<StaticResource x:Key="ButtonBorderBrush" ResourceKey="SidebarViewItemBorderBrush" />
														<StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="SidebarViewItemBorderBrushPointerOver" />
														<StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="SidebarViewItemBorderBrushPressed" />
														<StaticResource x:Key="ButtonBorderBrushDisabled" ResourceKey="SidebarViewItemBorderBrushDisabled" />
													</ResourceDictionary>
													<ResourceDictionary x:Key="Light">
														<StaticResource x:Key="ButtonBackground" ResourceKey="SidebarViewItemBackground" />
														<StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="SidebarViewItemBackgroundPointerOver" />
														<StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="SidebarViewItemBackgroundPressed" />
														<StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="SidebarViewItemBackgroundDisabled" />
														<StaticResource x:Key="ButtonBorderBrush" ResourceKey="SidebarViewItemBorderBrush" />
														<StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="SidebarViewItemBorderBrushPointerOver" />
														<StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="SidebarViewItemBorderBrushPressed" />
														<StaticResource x:Key="ButtonBorderBrushDisabled" ResourceKey="SidebarViewItemBorderBrushDisabled" />
													</ResourceDictionary>
												</ResourceDictionary.ThemeDictionaries>
											</ResourceDictionary>
										</Button.Resources>
									</Button>

									<ContentPresenter
										x:Name="PART_AutoSuggestBoxPresenter"
										Grid.Row="2"
										Margin="20,2"
										HorizontalAlignment="Stretch"
										VerticalAlignment="Stretch"
										HorizontalContentAlignment="Stretch"
										Content="{TemplateBinding AutoSuggestBox}" />

									<Button
										x:Name="PART_AutoSuggestButton"
										Grid.Row="2"
										Width="{StaticResource SidebarViewPaneButtonWidth}"
										Height="{StaticResource SidebarViewPaneButtonHeight}"
										Margin="8,0,8,4"
										HorizontalAlignment="Left"
										AutomationProperties.Name="Search"
										ToolTipService.ToolTip="Search"
										Visibility="Collapsed">
										<AnimatedIcon
											Width="16"
											Height="16"
											HorizontalAlignment="Center"
											VerticalAlignment="Center"
											AnimatedIcon.State="Normal"
											AutomationProperties.AccessibilityView="Raw">
											<animatedvisuals:AnimatedFindVisualSource />
											<AnimatedIcon.FallbackIconSource>
												<FontIconSource
													FontSize="16"
													Glyph="&#xE700;"
													MirroredWhenRightToLeft="True" />
											</AnimatedIcon.FallbackIconSource>
										</AnimatedIcon>
										<Button.Resources>
											<ResourceDictionary>
												<ResourceDictionary.ThemeDictionaries>
													<ResourceDictionary x:Key="Default">
														<StaticResource x:Key="ButtonBackground" ResourceKey="SidebarViewItemBackground" />
														<StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="SidebarViewItemBackgroundPointerOver" />
														<StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="SidebarViewItemBackgroundPressed" />
														<StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="SidebarViewItemBackgroundDisabled" />
														<StaticResource x:Key="ButtonBorderBrush" ResourceKey="SidebarViewItemBorderBrush" />
														<StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="SidebarViewItemBorderBrushPointerOver" />
														<StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="SidebarViewItemBorderBrushPressed" />
														<StaticResource x:Key="ButtonBorderBrushDisabled" ResourceKey="SidebarViewItemBorderBrushDisabled" />
													</ResourceDictionary>
													<ResourceDictionary x:Key="HighContrast">
														<StaticResource x:Key="ButtonBackground" ResourceKey="SidebarViewItemBackground" />
														<StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="SidebarViewItemBackgroundPointerOver" />
														<StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="SidebarViewItemBackgroundPressed" />
														<StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="SidebarViewItemBackgroundDisabled" />
														<StaticResource x:Key="ButtonBorderBrush" ResourceKey="SidebarViewItemBorderBrush" />
														<StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="SidebarViewItemBorderBrushPointerOver" />
														<StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="SidebarViewItemBorderBrushPressed" />
														<StaticResource x:Key="ButtonBorderBrushDisabled" ResourceKey="SidebarViewItemBorderBrushDisabled" />
													</ResourceDictionary>
													<ResourceDictionary x:Key="Light">
														<StaticResource x:Key="ButtonBackground" ResourceKey="SidebarViewItemBackground" />
														<StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="SidebarViewItemBackgroundPointerOver" />
														<StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="SidebarViewItemBackgroundPressed" />
														<StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="SidebarViewItemBackgroundDisabled" />
														<StaticResource x:Key="ButtonBorderBrush" ResourceKey="SidebarViewItemBorderBrush" />
														<StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="SidebarViewItemBorderBrushPointerOver" />
														<StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="SidebarViewItemBorderBrushPressed" />
														<StaticResource x:Key="ButtonBorderBrushDisabled" ResourceKey="SidebarViewItemBorderBrushDisabled" />
													</ResourceDictionary>
												</ResourceDictionary.ThemeDictionaries>
											</ResourceDictionary>
										</Button.Resources>
									</Button>

									<ScrollViewer
										Grid.Row="3"
										HorizontalAlignment="Stretch"
										VerticalAlignment="Stretch"
										HorizontalScrollMode="Disabled"
										VerticalScrollBarVisibility="Auto"
										XYFocusKeyboardNavigation="Enabled">
										<ItemsRepeater
											x:Name="PART_MenuItemsHost"
											Margin="{StaticResource SidebarViewItemsControlMargin}"
											HorizontalAlignment="Stretch"
											ItemTemplate="{StaticResource DefaultSidebarViewFlatItemTemplate}"
											XYFocusKeyboardNavigation="Enabled">
											<ItemsRepeater.Layout>
												<StackLayout Spacing="{StaticResource SidebarViewItemsControlSpacing}" />
											</ItemsRepeater.Layout>
										</ItemsRepeater>
									</ScrollViewer>

									<ItemsRepeater
										x:Name="PART_FooterMenuItemsHost"
										Grid.Row="4"
										Margin="{StaticResource SidebarViewItemsControlMargin}"
										HorizontalAlignment="Stretch"
										ItemTemplate="{StaticResource DefaultSidebarViewFlatItemTemplate}"
										XYFocusKeyboardNavigation="Enabled">
										<ItemsRepeater.Layout>
											<StackLayout Spacing="{StaticResource SidebarViewItemsControlSpacing}" />
										</ItemsRepeater.Layout>
									</ItemsRepeater>
								</Grid>
							</SplitView.Pane>

							<SplitView.Content>
								<Grid
									x:Name="PART_ContentGrid"
									Margin="{ThemeResource SidebarViewContentMargin}"
									Background="{StaticResource CardBackgroundFillColorDefault}"
									BorderBrush="{ThemeResource SidebarViewContentBorderBrush}"
									BorderThickness="{ThemeResource SidebarViewContentBorderThickness}"
									CornerRadius="{ThemeResource SidebarViewContentCornerRadius}">

									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="*" />
									</Grid.RowDefinitions>

									<ContentPresenter
										x:Name="HeaderContentPresenter"
										Margin="56,44,0,0"
										Content="{TemplateBinding Header}"
										Style="{StaticResource SidebarViewTitleHeaderTextStyle}"
										Visibility="Collapsed" />

									<ContentPresenter
										x:Name="ContentPresenter"
										Grid.Row="1"
										VerticalAlignment="Stretch"
										HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
										VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
										Content="{TemplateBinding Content}"
										ContentTemplate="{TemplateBinding ContentTemplate}"
										TabFocusNavigation="Local" />

									<Grid
										x:Name="PART_PaneLightDismissLayer"
										Grid.RowSpan="2"
										HorizontalAlignment="Stretch"
										VerticalAlignment="Stretch"
										Background="Transparent"
										Canvas.ZIndex="10"
										Visibility="Collapsed" />

									<Border
										x:Name="PART_SidebarResizer"
										Grid.RowSpan="2"
										MinWidth="4"
										Margin="0,60,0,40"
										HorizontalAlignment="Left"
										AllowFocusOnInteraction="True"
										Background="Transparent"
										BorderBrush="Transparent"
										Canvas.ZIndex="100"
										CornerRadius="2"
										ManipulationMode="TranslateX">
										<UserControl
											x:Name="PART_SidebarResizerControl"
											IsTabStop="True"
											UseSystemFocusVisuals="True" />
									</Border>
								</Grid>
							</SplitView.Content>

						</SplitView>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="DisplayModes">
								<VisualState x:Name="Expanded">
									<VisualState.Setters>
										<Setter Target="PART_PaneColumnGrid.Background" Value="Transparent" />
										<Setter Target="PART_PaneColumnGrid.BorderBrush" Value="Transparent" />
										<Setter Target="PART_PaneColumnGrid.BorderThickness" Value="0" />
										<Setter Target="PART_PaneLightDismissLayer.Visibility" Value="Collapsed" />
										<Setter Target="PART_SidebarResizer.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Compact">
									<VisualState.Setters>
										<Setter Target="PART_PaneColumnGrid.Background" Value="Transparent" />
										<Setter Target="PART_PaneColumnGrid.BorderBrush" Value="Transparent" />
										<Setter Target="PART_PaneColumnGrid.BorderThickness" Value="0" />
										<Setter Target="PART_PaneLightDismissLayer.Visibility" Value="Collapsed" />
										<Setter Target="PART_SidebarResizer.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="MinimalCollapsed">
									<VisualState.Setters>
										<Setter Target="PART_PaneColumnGrid.Background" Value="Transparent" />
										<Setter Target="PART_PaneColumnGrid.BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
										<Setter Target="PART_PaneColumnGrid.BorderThickness" Value="0,0,1,0" />
										<Setter Target="PART_PaneLightDismissLayer.Visibility" Value="Collapsed" />
										<Setter Target="PART_SidebarResizer.Visibility" Value="Collapsed" />
										<Setter Target="PART_ContentGrid.BorderThickness" Value="{ThemeResource SidebarViewContentBorderThicknessClosedCompact}" />
										<Setter Target="PART_ContentGrid.CornerRadius" Value="{ThemeResource SidebarViewContentCornerRadiusClosedCompact}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="MinimalExpanded">
									<VisualState.Setters>
										<Setter Target="PART_PaneColumnGrid.Background" Value="Transparent" />
										<Setter Target="PART_PaneColumnGrid.BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
										<Setter Target="PART_PaneColumnGrid.BorderThickness" Value="0,0,1,0" />
										<Setter Target="PART_PaneLightDismissLayer.Visibility" Value="Visible" />
										<Setter Target="PART_SidebarResizer.Visibility" Value="Collapsed" />
										<Setter Target="PART_ContentGrid.BorderThickness" Value="{ThemeResource SidebarViewContentBorderThicknessClosedCompact}" />
										<Setter Target="PART_ContentGrid.CornerRadius" Value="{ThemeResource SidebarViewContentCornerRadiusClosedCompact}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="PaneOverlayGroup">
								<VisualState x:Name="PaneOverlaying" />
								<VisualState x:Name="PaneNotOverlaying">
									<VisualState.Setters>
										<Setter Target="PART_RootSplitView.PaneBackground" Value="{ThemeResource SidebarViewExpandedPaneBackground}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="PaneStateGroup">
								<VisualState x:Name="NotClosedCompact" />
								<VisualState x:Name="ClosedCompact">
									<VisualState.Setters>
										<Setter Target="PART_AutoSuggestBoxPresenter.Visibility" Value="Collapsed" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="PaneStateListSizeGroup">
								<VisualState x:Name="ListSizeFull" />
								<VisualState x:Name="ListSizeCompact">
									<VisualState.Setters>
										<Setter Target="PART_PaneColumnGrid.Width" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=CompactPaneLength}" />
										<Setter Target="PART_PaneColumnGrid.HorizontalAlignment" Value="Left" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="ResizerStates">
								<VisualState x:Name="ResizerNormal" />
								<VisualState x:Name="ResizerPointerOver">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="PART_SidebarResizer" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource CardStrokeColorDefaultSolidBrush}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="PART_SidebarResizer" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource CardStrokeColorDefaultSolidBrush}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
								<VisualState x:Name="ResizerPressed">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="PART_SidebarResizer" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SolidBackgroundFillColorSecondaryBrush}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="PART_SidebarResizer" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SolidBackgroundFillColorSecondaryBrush}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="HeaderStates">
								<VisualState x:Name="HeaderCollapsed" />
								<VisualState x:Name="HeaderVisible">
									<VisualState.Setters>
										<Setter Target="HeaderContentPresenter.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

						</VisualStateManager.VisualStateGroups>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="SidebarViewTitleHeaderTextStyle" TargetType="ContentPresenter">
		<Setter Property="FontWeight" Value="SemiBold" />
		<Setter Property="FontSize" Value="28" />
		<Setter Property="FontFamily" Value="XamlAutoFontFamily" />
		<Setter Property="Margin" Value="{ThemeResource NavigationViewHeaderMargin}" />
		<Setter Property="VerticalAlignment" Value="Stretch" />
	</Style>

</ResourceDictionary>
