<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:Files.App.Controls">

	<Style BasedOn="{StaticResource DefaultSidebarViewItemStyle}" TargetType="local:SidebarViewItem" />
	<Style BasedOn="{StaticResource DefaultSidebarViewSeparatorItemStyle}" TargetType="local:SidebarViewSeparatorItem" />

	<x:Double x:Key="SidebarViewItemHeight">32</x:Double>
	<Thickness x:Key="SidebarViewSeparatorDividerMargin">4,8,4,8</Thickness>
	<x:Double x:Key="SidebarViewSeparatorDividerStrokeHeight">1</x:Double>

	<Style x:Key="DefaultSidebarViewItemStyle" TargetType="local:SidebarViewItem">
		<Setter Property="IsTabStop" Value="True" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="local:SidebarViewItem">
					<Grid x:Name="RootPanel">
						<Grid
							x:Name="PART_RootGrid"
							Height="{StaticResource SidebarViewItemHeight}"
							MinHeight="{StaticResource SidebarViewItemHeight}"
							BorderThickness="1"
							CornerRadius="{ThemeResource ControlCornerRadius}"
							ToolTipService.ToolTip="{TemplateBinding ToolTip}"
							UseSystemFocusVisuals="True">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="3" />
								<ColumnDefinition x:Name="IndentColumnDefinition" Width="Auto" />
								<ColumnDefinition x:Name="ChevronColumnDefinition" Width="16" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Grid.BackgroundTransition>
								<BrushTransition Duration="0:0:0.083" />
							</Grid.BackgroundTransition>

							<Border
								x:Name="SelectionIndicator"
								Grid.Column="0"
								Width="3"
								Height="16"
								HorizontalAlignment="Left"
								VerticalAlignment="Center"
								Background="{ThemeResource SidebarViewItemSelectionIndicatorBackground}"
								CornerRadius="2"
								Opacity="0">
								<Border.BackgroundTransition>
									<BrushTransition Duration="0:0:0.083" />
								</Border.BackgroundTransition>
							</Border>

							<Border Grid.Column="1" Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.IndentWidth}" />

							<Border
								x:Name="PART_ChevronContainer"
								Grid.Column="2"
								HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch"
								Background="Transparent"
								Opacity="{TemplateBinding ContentOpacity}">
								<FontIcon
									x:Name="ExpandCollapseChevron"
									Width="12"
									Height="12"
									HorizontalAlignment="Center"
									VerticalAlignment="Center"
									AutomationProperties.AccessibilityView="Raw"
									FontFamily="{StaticResource SymbolThemeFontFamily}"
									FontSize="10"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}"
									Glyph="&#xE76C;"
									IsTextScaleFactorEnabled="False"
									RenderTransformOrigin="0.5,0.5"
									Visibility="Collapsed">
									<FontIcon.RenderTransform>
										<RotateTransform x:Name="ExpandCollapseChevronRotateTransform" Angle="0" />
									</FontIcon.RenderTransform>
								</FontIcon>
							</Border>

							<ContentPresenter
								x:Name="ItemIconPresenter"
								Grid.Column="3"
								Width="16"
								Height="16"
								Margin="4,0,0,0"
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								AutomationProperties.AccessibilityView="Raw"
								Content="{TemplateBinding Icon}"
								Opacity="{TemplateBinding ContentOpacity}" />

							<ContentPresenter
								x:Name="ItemNameTextBlock"
								Grid.Column="4"
								Margin="12,0,12,0"
								VerticalAlignment="Center"
								AutomationProperties.AccessibilityView="Raw"
								Content="{TemplateBinding Text}"
								Opacity="{TemplateBinding ContentOpacity}" />

							<ContentPresenter
								x:Name="ItemDecoratorContentPresenter"
								Grid.Column="5"
								Margin="0,0,8,0"
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								HorizontalContentAlignment="Center"
								VerticalContentAlignment="Center"
								AutomationProperties.AccessibilityView="Raw"
								Content="{TemplateBinding Decorator}"
								Opacity="{TemplateBinding ContentOpacity}" />

							<FlyoutBase.AttachedFlyout>
								<Flyout x:Name="PART_ChildrenFlyout" Placement="Right">
									<Flyout.FlyoutPresenterStyle>
										<Style BasedOn="{StaticResource DefaultFlyoutPresenterStyle}" TargetType="FlyoutPresenter">
											<Setter Target="Padding" Value="0,4" />
											<Setter Target="MinWidth" Value="200" />
											<Setter Target="MinHeight" Value="20" />
										</Style>
									</Flyout.FlyoutPresenterStyle>
									<ItemsRepeater
										x:Name="PART_FlyoutChildrenPresenter"
										Margin="{StaticResource SidebarViewItemsControlMargin}"
										HorizontalAlignment="Stretch"
										AutomationProperties.AccessibilityView="Content"
										XYFocusKeyboardNavigation="Enabled">
										<ItemsRepeater.Layout>
											<StackLayout Spacing="4" />
										</ItemsRepeater.Layout>
										<ItemsRepeater.ItemTemplate>
											<DataTemplate>
												<local:SidebarViewItem
													AutomationProperties.AutomationId="{Binding Text}"
													Decorator="{Binding ItemDecorator}"
													Icon="{Binding IconElement}"
													IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
													IsInFlyout="True"
													Item="{Binding}"
													ItemValue="{Binding}"
													Text="{Binding Text}"
													ToolTip="{Binding ToolTip}" />
											</DataTemplate>
										</ItemsRepeater.ItemTemplate>
									</ItemsRepeater>
								</Flyout>
							</FlyoutBase.AttachedFlyout>
						</Grid>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="SelectionStates">
								<VisualState x:Name="Unselected">
									<VisualState.Setters>
										<Setter Target="SelectionIndicator.Opacity" Value="0" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Selected">
									<VisualState.Setters>
										<Setter Target="SelectionIndicator.Opacity" Value="1" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="ExpansionStates">
								<VisualState x:Name="NoChildren" />
								<VisualState x:Name="LeafWithChildren" />
								<VisualState x:Name="Collapsed" />
								<VisualState x:Name="Expanded" />
								<VisualState x:Name="ChildrenInFlyout" />
							</VisualStateGroup>

							<VisualStateGroup x:Name="ChevronStates">
								<VisualState x:Name="ChevronHidden" />
								<VisualState x:Name="ChevronVisibleOpen">
									<VisualState.Setters>
										<Setter Target="ExpandCollapseChevron.Visibility" Value="Visible" />
										<Setter Target="ExpandCollapseChevronRotateTransform.Angle" Value="90" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="ChevronVisibleClosed">
									<VisualState.Setters>
										<Setter Target="ExpandCollapseChevron.Visibility" Value="Visible" />
										<Setter Target="ExpandCollapseChevronRotateTransform.Angle" Value="0" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="PointerChevronStates">
								<VisualState x:Name="NormalChevronHidden" />
								<VisualState x:Name="NormalChevronVisibleOpen" />
								<VisualState x:Name="NormalChevronVisibleClosed" />
								<VisualState x:Name="PointerOverChevronHidden" />
								<VisualState x:Name="PointerOverChevronVisibleOpen" />
								<VisualState x:Name="PointerOverChevronVisibleClosed" />
								<VisualState x:Name="PressedChevronHidden" />
								<VisualState x:Name="PressedChevronVisibleOpen" />
								<VisualState x:Name="PressedChevronVisibleClosed" />
							</VisualStateGroup>

							<VisualStateGroup x:Name="BackgroundStates">
								<VisualState x:Name="NormalUnselected">
									<VisualState.Setters>
										<Setter Target="PART_RootGrid.Background" Value="{ThemeResource SidebarViewItemBackground}" />
										<Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource SidebarViewItemBorderBrush}" />
										<Setter Target="SelectionIndicator.Background" Value="{ThemeResource SidebarViewItemSelectionIndicatorBackground}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="NormalSelected">
									<VisualState.Setters>
										<Setter Target="PART_RootGrid.Background" Value="{ThemeResource SidebarViewItemBackgroundSelected}" />
										<Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource SidebarViewItemBorderBrushSelected}" />
										<Setter Target="SelectionIndicator.Background" Value="{ThemeResource SidebarViewItemSelectionIndicatorBackground}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="PointerOverUnselected">
									<VisualState.Setters>
										<Setter Target="PART_RootGrid.Background" Value="{ThemeResource SidebarViewItemBackgroundPointerOver}" />
										<Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource SidebarViewItemBorderBrushPointerOver}" />
										<Setter Target="SelectionIndicator.Background" Value="{ThemeResource SidebarViewItemSelectionIndicatorBackground}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="PointerOverSelected">
									<VisualState.Setters>
										<Setter Target="PART_RootGrid.Background" Value="{ThemeResource SidebarViewItemBackgroundSelectedPointerOver}" />
										<Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource SidebarViewItemBorderBrushSelectedPointerOver}" />
										<Setter Target="SelectionIndicator.Background" Value="{ThemeResource SidebarViewItemSelectionIndicatorBackgroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="PressedUnselected">
									<VisualState.Setters>
										<Setter Target="PART_RootGrid.Background" Value="{ThemeResource SidebarViewItemBackgroundPressed}" />
										<Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource SidebarViewItemBorderBrushPressed}" />
										<Setter Target="SelectionIndicator.Background" Value="{ThemeResource SidebarViewItemSelectionIndicatorBackground}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="PressedSelected">
									<VisualState.Setters>
										<Setter Target="PART_RootGrid.Background" Value="{ThemeResource SidebarViewItemBackgroundSelectedPressed}" />
										<Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource SidebarViewItemBorderBrushSelectedPressed}" />
										<Setter Target="SelectionIndicator.Background" Value="{ThemeResource SidebarViewItemSelectionIndicatorBackgroundPressed}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="DisplayModeStates">
								<VisualState x:Name="NonCompact" />
								<VisualState x:Name="Compact">
									<VisualState.Setters>
										<Setter Target="IndentColumnDefinition.Width" Value="0" />
										<Setter Target="ChevronColumnDefinition.Width" Value="0" />
										<Setter Target="PART_ChevronContainer.Visibility" Value="Collapsed" />
										<Setter Target="ItemIconPresenter.Margin" Value="8,0,0,0" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="DefaultSidebarViewSeparatorItemStyle" TargetType="local:SidebarViewSeparatorItem">
		<Setter Property="IsHitTestVisible" Value="False" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="local:SidebarViewSeparatorItem">
					<Border
						Height="{StaticResource SidebarViewSeparatorDividerStrokeHeight}"
						Margin="{StaticResource SidebarViewSeparatorDividerMargin}"
						Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
