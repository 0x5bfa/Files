<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
	xmlns:local="using:Files.App.Controls">

	<Style BasedOn="{StaticResource DefaultSidebarViewItemStyle}" TargetType="local:SidebarViewItem" />
	<Style BasedOn="{StaticResource DefaultSidebarViewSeparatorItemStyle}" TargetType="local:SidebarViewSeparatorItem" />

	<Thickness x:Key="SidebarViewItemMargin">4,0,4,0</Thickness>
	<x:Double x:Key="SidebarViewItemHeight">32</x:Double>
	<x:Double x:Key="SidebarViewItemsControlSpacing">4</x:Double>
	<Thickness x:Key="SidebarViewItemItemsControlMargin">0,4,0,0</Thickness>

	<x:Double x:Key="SidebarViewHeaderItemHeight">32</x:Double>

	<Thickness x:Key="SidebarViewSeparatorDividerMargin">4,8,4,8</Thickness>
	<x:Double x:Key="SidebarViewSeparatorDividerStrokeHeight">1</x:Double>

	<Style x:Key="DefaultSidebarViewItemStyle" TargetType="local:SidebarViewItem">
		<Setter Property="IsTabStop" Value="True" />
		<Setter Property="Margin" Value="{StaticResource SidebarViewItemMargin}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="local:SidebarViewItem">
					<Grid x:Name="RootPanel">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<Grid.BackgroundTransition>
							<BrushTransition Duration="0:0:0.083" />
						</Grid.BackgroundTransition>

						<Grid
							x:Name="PART_RootGrid"
							MinHeight="{StaticResource SidebarViewItemHeight}"
							BorderThickness="1"
							CornerRadius="{ThemeResource ControlCornerRadius}"
							ToolTipService.ToolTip="{TemplateBinding ToolTip}"
							UseSystemFocusVisuals="True">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Grid.BackgroundTransition>
								<BrushTransition Duration="0:0:0.083" />
							</Grid.BackgroundTransition>

							<Border
								x:Name="SelectionIndicator"
								Grid.Column="0"
								Width="3"
								Height="16"
								HorizontalAlignment="Left"
								VerticalAlignment="Center"
								Background="{ThemeResource AccentFillColorDefaultBrush}"
								CornerRadius="2"
								Opacity="0"
								RenderTransformOrigin="0.5,0.5">
								<Border.RenderTransform>
									<ScaleTransform x:Name="SelectionIndicatorScaleTransform" ScaleX="1" ScaleY="1" />
								</Border.RenderTransform>
								<Border.BackgroundTransition>
									<BrushTransition Duration="0:0:0.083" />
								</Border.BackgroundTransition>
							</Border>

							<ContentPresenter
								x:Name="ItemIconPresenter"
								Grid.Column="1"
								Width="16"
								Height="16"
								Margin="8,0,0,0"
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								Content="{TemplateBinding Icon}" />

							<AnimatedIcon
								x:Name="ExpandCollapseChevron"
								Grid.Column="4"
								Width="{StaticResource ExpanderChevronGlyphSize}"
								Height="{StaticResource ExpanderChevronGlyphSize}"
								Margin="0,0,8,0"
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								AnimatedIcon.State="NormalOff"
								Foreground="{ThemeResource TextFillColorSecondaryBrush}"
								RenderTransformOrigin="0.5,0.5"
								Visibility="Collapsed">
								<animatedvisuals:AnimatedChevronUpDownSmallVisualSource />
								<AnimatedIcon.FallbackIconSource>
									<FontIconSource
										FontFamily="{StaticResource SymbolThemeFontFamily}"
										FontSize="12"
										Glyph="{StaticResource ExpanderChevronDownGlyph}"
										IsTextScaleFactorEnabled="False" />
								</AnimatedIcon.FallbackIconSource>
								<AnimatedIcon.RenderTransform>
									<RotateTransform x:Name="ExpandCollapseChevronRotateTransform" Angle="0" />
								</AnimatedIcon.RenderTransform>
							</AnimatedIcon>

							<TextBlock
								x:Name="ItemNameTextBlock"
								Grid.Column="2"
								Margin="12,0,12,0"
								VerticalAlignment="Center"
								Text="{TemplateBinding Text}"
								TextTrimming="CharacterEllipsis"
								TextWrapping="NoWrap" />

							<ContentPresenter
								x:Name="ItemDecoratorContentPresenter"
								Grid.Column="3"
								Width="28"
								Margin="0,0,8,0"
								HorizontalAlignment="Stretch"
								VerticalAlignment="Center"
								HorizontalContentAlignment="Center"
								VerticalContentAlignment="Center"
								Content="{TemplateBinding Decorator}"
								Visibility="Collapsed" />

							<!--  Overflow  -->
							<FlyoutBase.AttachedFlyout>
								<Flyout x:Name="ChildrenFlyout" Placement="Right">
									<Flyout.FlyoutPresenterStyle>
										<Style BasedOn="{StaticResource DefaultFlyoutPresenterStyle}" TargetType="FlyoutPresenter">
											<Setter Target="Padding" Value="0,4" />
											<Setter Target="MinWidth" Value="200" />
											<Setter Target="MinHeight" Value="20" />
										</Style>
									</Flyout.FlyoutPresenterStyle>
									<ContentPresenter x:Name="ChildrenOverflowFlyoutContentPresenter" />
								</Flyout>
							</FlyoutBase.AttachedFlyout>
						</Grid>

						<ItemsControl
							x:Name="PART_ChildrenItemsControl"
							Grid.Row="1"
							Margin="{StaticResource SidebarViewItemItemsControlMargin}"
							HorizontalAlignment="Stretch"
							ItemTemplate="{TemplateBinding ChildItemTemplate}"
							ItemTemplateSelector="{TemplateBinding ChildItemTemplateSelector}"
							ItemsSource="{TemplateBinding Children}"
							Visibility="Collapsed"
							XYFocusKeyboardNavigation="Enabled">
							<ItemsControl.ItemContainerStyle>
								<Style TargetType="ContentPresenter">
									<Setter Property="HorizontalAlignment" Value="Stretch" />
								</Style>
							</ItemsControl.ItemContainerStyle>
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<StackPanel Orientation="Vertical" Spacing="{StaticResource SidebarViewItemsControlSpacing}" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
						</ItemsControl>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="SelectionStates">
								<VisualState x:Name="Unselected" />
								<VisualState x:Name="Selected">
									<VisualState.Setters>
										<Setter Target="SelectionIndicator.Opacity" Value="1" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="ExpansionStates">
								<VisualState x:Name="NoExpansion">
									<VisualState.Setters>
										<Setter Target="ItemNameTextBlock.Visibility" Value="Collapsed" />
										<Setter Target="ExpandCollapseChevron.Visibility" Value="Collapsed" />
										<Setter Target="PART_ChildrenItemsControl.Visibility" Value="Collapsed" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="NoChildren">
									<VisualState.Setters>
										<Setter Target="ExpandCollapseChevron.Visibility" Value="Collapsed" />
										<Setter Target="PART_ChildrenItemsControl.Visibility" Value="Collapsed" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Collapsed">
									<VisualState.Setters>
										<Setter Target="ExpandCollapseChevron.Visibility" Value="Visible" />
										<Setter Target="PART_ChildrenItemsControl.Visibility" Value="Collapsed" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Expanded">
									<VisualState.Setters>
										<Setter Target="ExpandCollapseChevron.Visibility" Value="Visible" />
										<Setter Target="PART_ChildrenItemsControl.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="ExpansionIconStates">
								<VisualState x:Name="ExpandedIconNormal">
									<VisualState.Setters>
										<Setter Target="ExpandCollapseChevron.(AnimatedIcon.State)" Value="NormalOn" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="ExpandedIconPressed">
									<VisualState.Setters>
										<Setter Target="ExpandCollapseChevron.(AnimatedIcon.State)" Value="PressedOn" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CollapsedIconNormal">
									<VisualState.Setters>
										<Setter Target="ExpandCollapseChevron.(AnimatedIcon.State)" Value="NormalOff" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CollapsedIconPressed">
									<VisualState.Setters>
										<Setter Target="ExpandCollapseChevron.(AnimatedIcon.State)" Value="PressedOff" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="BackgroundStates">
								<!--<VisualStateGroup.Transitions>
									<VisualTransition From="NormalSelected" To="PointerOverSelected">
										<Storyboard>
											<DoubleAnimation
												Storyboard.TargetName="SelectionIndicator"
												Storyboard.TargetProperty="Opacity"
												To="1"
												Duration="0:0:0.083" />
											<DoubleAnimation
												Storyboard.TargetName="SelectionIndicatorScaleTransform"
												Storyboard.TargetProperty="ScaleY"
												To="1"
												Duration="0:0:0.167">
												<DoubleAnimation.EasingFunction>
													<CubicEase EasingMode="EaseOut" />
												</DoubleAnimation.EasingFunction>
											</DoubleAnimation>
										</Storyboard>
									</VisualTransition>
									<VisualTransition From="PointerOverSelected" To="NormalSelected">
										<Storyboard>
											<DoubleAnimation
												Storyboard.TargetName="SelectionIndicator"
												Storyboard.TargetProperty="Opacity"
												To="1"
												Duration="0:0:0.083" />
											<DoubleAnimation
												Storyboard.TargetName="SelectionIndicatorScaleTransform"
												Storyboard.TargetProperty="ScaleY"
												To="1"
												Duration="0:0:0.167">
												<DoubleAnimation.EasingFunction>
													<CubicEase EasingMode="EaseOut" />
												</DoubleAnimation.EasingFunction>
											</DoubleAnimation>
										</Storyboard>
									</VisualTransition>
									<VisualTransition From="PointerOverSelected" To="PressedSelected">
										<Storyboard>
											<DoubleAnimation
												Storyboard.TargetName="SelectionIndicator"
												Storyboard.TargetProperty="Opacity"
												To="1"
												Duration="0:0:0.083" />
											<DoubleAnimation
												Storyboard.TargetName="SelectionIndicatorScaleTransform"
												Storyboard.TargetProperty="ScaleY"
												To="0.7"
												Duration="0:0:0.083">
												<DoubleAnimation.EasingFunction>
													<CubicEase EasingMode="EaseOut" />
												</DoubleAnimation.EasingFunction>
											</DoubleAnimation>
										</Storyboard>
									</VisualTransition>
									<VisualTransition From="PressedSelected" To="PointerOverSelected">
										<Storyboard>
											<DoubleAnimation
												Storyboard.TargetName="SelectionIndicator"
												Storyboard.TargetProperty="Opacity"
												To="1"
												Duration="0:0:0.083" />
											<DoubleAnimation
												Storyboard.TargetName="SelectionIndicatorScaleTransform"
												Storyboard.TargetProperty="ScaleY"
												To="1"
												Duration="0:0:0.167">
												<DoubleAnimation.EasingFunction>
													<CubicEase EasingMode="EaseOut" />
												</DoubleAnimation.EasingFunction>
											</DoubleAnimation>
										</Storyboard>
									</VisualTransition>
								</VisualStateGroup.Transitions>-->
								<VisualState x:Name="NormalUnselected">
									<VisualState.Setters>
										<Setter Target="PART_RootGrid.Background" Value="{ThemeResource SubtleFillColorTransparentBrush}" />
										<Setter Target="PART_RootGrid.BorderBrush" Value="Transparent" />
										<Setter Target="SelectionIndicator.Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="NormalSelected">
									<VisualState.Setters>
										<Setter Target="PART_RootGrid.Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
										<Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
										<Setter Target="SelectionIndicator.Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
										<!--<Setter Target="SelectionIndicatorScaleTransform.ScaleY" Value="1" />
										<Setter Target="SelectionIndicator.Opacity" Value="1" />-->
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="PointerOverUnselected">
									<VisualState.Setters>
										<Setter Target="PART_RootGrid.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
										<Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
										<Setter Target="SelectionIndicator.Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="PointerOverSelected">
									<VisualState.Setters>
										<Setter Target="PART_RootGrid.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
										<Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
										<Setter Target="SelectionIndicator.Background" Value="{ThemeResource AccentFillColorSecondaryBrush}" />
										<!--<Setter Target="SelectionIndicatorScaleTransform.ScaleY" Value="1" />
										<Setter Target="SelectionIndicator.Opacity" Value="1" />-->
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="PressedUnselected">
									<VisualState.Setters>
										<Setter Target="PART_RootGrid.Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
										<Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
										<Setter Target="SelectionIndicator.Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="PressedSelected">
									<VisualState.Setters>
										<Setter Target="PART_RootGrid.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
										<Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
										<Setter Target="SelectionIndicator.Background" Value="{ThemeResource AccentFillColorTertiaryBrush}" />
										<!--<Setter Target="SelectionIndicatorScaleTransform.ScaleY" Value="0.7" />
										<Setter Target="SelectionIndicator.Opacity" Value="1" />-->
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="DefaultSidebarViewSeparatorItemStyle" TargetType="local:SidebarViewSeparatorItem">
		<Setter Property="IsHitTestVisible" Value="False" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="local:SidebarViewSeparatorItem">
					<Border
						Height="{StaticResource SidebarViewSeparatorDividerStrokeHeight}"
						Margin="{StaticResource SidebarViewSeparatorDividerMargin}"
						Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
